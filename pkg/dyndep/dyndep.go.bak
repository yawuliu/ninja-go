package dyndep

import (
	"bufio"
	"fmt"
	"ninja-go/pkg/util"
	"os"
	"strings"

	"ninja-go/pkg/graph"
	"ninja-go/pkg/parser"
)

// LoadAndAddEdges 读取 dyndep 文件，解析其中的 build 语句，将新边添加到 state 中。
// 返回新添加的边列表。
func LoadAndAddEdges(state *graph.State, dyndepPath string) ([]*graph.Edge, error) {
	f, err := os.Open(dyndepPath)
	if err != nil {
		return nil, fmt.Errorf("open dyndep file: %w", err)
	}
	defer f.Close()

	scanner := bufio.NewScanner(f)
	lineNo := 0
	var newEdges []*graph.Edge

	for scanner.Scan() {
		lineNo++
		raw := scanner.Text()
		// 去除注释（简化，不考虑转义）
		if idx := strings.Index(raw, "#"); idx >= 0 {
			raw = raw[:idx]
		}
		line := strings.TrimSpace(raw)
		if line == "" {
			continue
		}
		// dyndep 文件中只应包含 build 语句（也可能有变量，但我们简化，只处理 build）
		if strings.HasPrefix(line, "build") {
			// 解析 build 行
			edge, err := parseBuildLine(state, line, lineNo, dyndepPath)
			if err != nil {
				return nil, err
			}
			if edge != nil {
				newEdges = append(newEdges, edge)
			}
		}
		// 忽略其他内容（rule, default 等）
	}
	return newEdges, scanner.Err()
}

// parseBuildLine 解析一行 build 语句，创建 Edge 并添加到 state，返回该 Edge。
// 格式: build outputs: rule inputs | implicit || order-only
func parseBuildLine(state *graph.State, line string, lineNo int, source string) (*graph.Edge, error) {
	// 去掉行首 "build"
	rest := strings.TrimSpace(line[len("build"):])
	colonIdx := strings.Index(rest, ":")
	if colonIdx == -1 {
		return nil, fmt.Errorf("%s:%d: invalid build line", source, lineNo)
	}
	outputsPart := strings.TrimSpace(rest[:colonIdx])
	rest = strings.TrimSpace(rest[colonIdx+1:])
	outputs := strings.Fields(outputsPart)

	restFields := strings.Fields(rest)
	if len(restFields) < 1 {
		return nil, fmt.Errorf("%s:%d: missing rule name", source, lineNo)
	}
	ruleName := restFields[0]
	args := restFields[1:]

	// 解析 | 和 ||
	var inputs, implicit, orderOnly []string
	stateFlag := 0 // 0=inputs, 1=implicit, 2=orderOnly
	for _, arg := range args {
		if arg == "|" {
			stateFlag = 1
			continue
		} else if arg == "||" {
			stateFlag = 2
			continue
		}
		switch stateFlag {
		case 0:
			inputs = append(inputs, arg)
		case 1:
			implicit = append(implicit, arg)
		case 2:
			orderOnly = append(orderOnly, arg)
		}
	}

	// 查找 rule
	rule := state.Rules[ruleName]
	if rule == nil {
		return nil, fmt.Errorf("%s:%d: unknown rule %q", source, lineNo, ruleName)
	}

	// 创建边
	edge := &graph.Edge{Rule: rule}
	for _, out := range outputs {
		node := state.AddNode(util.NormalizePath(out))
		node.Generated = true
		node.Edge = edge
		edge.Outputs = append(edge.Outputs, node)
	}
	for _, in := range inputs {
		node := state.AddNode(util.NormalizePath(in))
		edge.Inputs = append(edge.Inputs, node)
	}
	for _, imp := range implicit {
		node := state.AddNode(util.NormalizePath(imp))
		edge.ImplicitDeps = append(edge.ImplicitDeps, node)
	}
	for _, ord := range orderOnly {
		node := state.AddNode(util.NormalizePath(ord))
		edge.OrderOnlyDeps = append(edge.OrderOnlyDeps, node)
	}

	state.Edges = append(state.Edges, edge)
	return edge, nil
}

// LoadAndApply 读取 dyndep 文件，将其中的 build 语句添加到 state 中，并返回新增的边
func LoadAndApply(state *graph.State, dyndepPath string) ([]*graph.Edge, error) {
	f, err := os.Open(dyndepPath)
	if err != nil {
		return nil, fmt.Errorf("open dyndep file: %v", err)
	}
	defer f.Close()

	// 使用 parser 解析 dyndep 文件，但只提取 build 语句，忽略 rule/default 等
	// 注意：dyndep 文件中的 build 语句必须引用已有的 rule
	p := parser.NewParser(state)
	// 我们需要一个只解析 build 语句的模式，但现有 parser 会完整解析
	// 为简化，可以复用 parser 但忽略非 build 内容（或让 parser 支持部分解析）
	// 临时方案：直接调用 parser.ParseReader，它会覆盖 state 的 edges 吗？不会，是追加。
	if err := p.ParseReader(f, dyndepPath); err != nil {
		return nil, err
	}
	// 返回新添加的边（需要跟踪新增的边，可以通过记录解析前的 edges 数量）
	// 这里简化：假设 state.Edges 新增的就是 dyndep 带来的，调用者可以自己比较
	return nil, nil
}
