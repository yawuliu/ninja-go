package dyndep

import (
	"os"
	"testing"

	"github.com/stretchr/testify/assert"
	"ninja-go/pkg/graph"
)

func TestLoadAndAddEdges(t *testing.T) {
	state := graph.NewState()
	// 添加一个规则
	state.Rules["cc"] = &graph.Rule{Name: "cc", Command: "gcc -c $in -o $out"}

	dyndepContent := `build generated.o: cc generated.c`
	dyndepFile := "test.dd"
	err := os.WriteFile(dyndepFile, []byte(dyndepContent), 0644)
	assert.NoError(t, err)
	defer os.Remove(dyndepFile)

	edges, err := LoadAndAddEdges(state, dyndepFile)
	assert.NoError(t, err)
	assert.Len(t, edges, 1)
	assert.Len(t, state.Edges, 1)
	assert.Equal(t, "generated.o", edges[0].Outputs[0].Path)
	assert.Equal(t, "generated.c", edges[0].Inputs[0].Path)
}
